# ─────────────────────────────────────────────────────────────────────────────
# CutMakers — variáveis de ambiente de PRODUÇÃO (modelo)
#
# No servidor, copie para:  packages/api/.env.production
# NUNCA commite o arquivo real com segredos. Só este .example com placeholders.
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados (Supabase — Postgres gerenciado) ──────────────────────────
# Decida: reaproveitar o projeto Supabase de dev OU criar um projeto separado de
# produção (RECOMENDADO — isola dados de teste dos reais).
# DATABASE_URL usa o pooler (porta 6543, pgbouncer). DIRECT_URL usa 5432 (migrations).
DATABASE_URL="postgresql://postgres.[ref]:[senha]@aws-0-[regiao].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[senha]@aws-0-[regiao].pooler.supabase.com:5432/postgres"

# ── Autenticação JWT ─────────────────────────────────────────────────────────
# ATENÇÃO: gere segredos NOVOS para produção. NUNCA reutilize os de dev.
#   openssl rand -base64 48
JWT_SECRET="TROQUE_por_segredo_novo_de_producao"
JWT_REFRESH_SECRET="TROQUE_por_outro_segredo_novo_de_producao"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Servidor ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3333

# CORS: origens permitidas (separadas por vírgula). Em produção, apenas o domínio público.
CORS_ORIGIN=https://cutmakers.derek.dev.br

# ── Cloudinary (uploads) ─────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# ── Abacatepay (pagamentos / escrow) ─────────────────────────────────────────
# Chave de produção compatível com a API v1. O webhook secret valida a assinatura HMAC.
ABACATEPAY_API_KEY=sua_chave_abacatepay
ABACATEPAY_WEBHOOK_SECRET=seu_webhook_secret

# ── URL pública do frontend (usada nos returnUrl do Abacatepay) ──────────────
FRONTEND_URL=https://cutmakers.derek.dev.br

# Opcional: dados de cobrança usados quando o usuário ainda não informou (Abacatepay exige)
# ABACATEPAY_FALLBACK_CELLPHONE="(11) 99999-9999"
# ABACATEPAY_FALLBACK_TAX_ID="529.982.247-25"

# ─────────────────────────────────────────────────────────────────────────────
# Build do FRONTEND (VITE_*) — assadas em BUILD TIME, passadas como ARG do Docker
# (ver docker-compose.yml → cutmakers-web.build.args).
# O app usa baseURL relativa '/api' por padrão, então isto é OPCIONAL.
# Só defina se for servir a API em outro domínio.
# ─────────────────────────────────────────────────────────────────────────────
# VITE_API_URL=/api
