# Bloco para adicionar ao Caddyfile central em ~/infra/
# HTTPS automático (mesmo padrão dos outros sites). Caddy alcança os
# containers pelo nome via rede `web`.

cutmakers.derek.dev.br {
	encode zstd gzip

	# API — encaminha /api/* para o container da API (mantém o prefixo /api)
	handle /api/* {
		reverse_proxy cutmakers-api:3333
	}

	# SPA — todo o resto vai para o nginx do frontend
	handle {
		reverse_proxy cutmakers-web:80
	}
}
